# 运行模式：normal（默认）或 demo（演示模式，需 token 鉴权）
# demo 模式启动：VIBE_MODE=demo docker compose up -d --build
# token 首次自动生成，从后端日志查看：docker logs vibe-backend | grep "Demo mode"
VIBE_MODE=normal

# 前端宿主机端口（nginx 暴露端口）
FRONTEND_PORT=8080
FRONTEND_HTTPS_PORT=8443

# API key 与 base_url（可选）：填了会覆盖 config.yaml 里对应字段。
# 留空则使用 config/config.yaml 中的值；api_key 三层都为空时，
# 前端启动后会弹窗要求填写 base_url 与 api_key（每次刷新页面都需要重填）。
VIBE_API_KEY=
VIBE_BASE_URL=

# 持久化目录 bind mount（支持 Windows / Linux 自定义路径）
# 默认相对路径，下面是覆盖示例（取消注释并修改）：
# Linux:   VIBE_DATA_DIR=/opt/vibeImage/data
# Windows: VIBE_DATA_DIR=D:/vibeImage/data
VIBE_CONFIG_DIR=./config
VIBE_DATA_DIR=./data
VIBE_IMAGES_DIR=./images
VIBE_PROMPT_DIR=./prompt

# HTTPS 证书目录（自签或正式都行；放 cert.pem 和 key.pem 两个文件）
VIBE_CERTS_DIR=./docker/certs
